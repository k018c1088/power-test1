---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404 - Not Found">
  <Header slot="header" />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-20 text-center">
    <div class="text-8xl font-black bg-clip-text text-transparent bg-gradient-to-r from-primary-400 to-accent-500 mb-4">
      404
    </div>
    <h1 class="text-2xl font-bold mb-4">Page Not Found</h1>
    <p class="text-surface-800/60 dark:text-surface-200/60 mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/blog-modern/"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary-500 text-white font-medium hover:bg-primary-600 transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back to Home
    </a>
  </div>

  <Footer slot="footer" />
</BaseLayout>
