---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import TagCloud from '../../components/TagCloud.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getPublishedPosts, getAllTags, getPostsByTag } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tagSet = new Set<string>();
  posts.forEach((post) => post.data.tags.forEach((tag) => tagSet.add(tag)));

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const posts = await getPostsByTag(tag);
const allTags = await getAllTags();
---

<BaseLayout title={`#${tag}`} description={`Articles tagged with ${tag}`}>
  <Header slot="header" />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <h1 class="text-3xl font-extrabold mb-2">#{tag}</h1>
    <p class="text-surface-800/60 dark:text-surface-200/60 mb-8">
      {posts.length} article{posts.length !== 1 ? 's' : ''}
    </p>

    <div class="mb-8">
      <TagCloud tags={allTags} activeTag={tag} />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post, i) => <ArticleCard post={post} index={i} />)}
    </div>
  </div>

  <Footer slot="footer" />
  <BackToTop />
</BaseLayout>
