---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getAllTags } from '../../utils/posts';

const tags = await getAllTags();
---

<BaseLayout title="Tags" description="All tags">
  <Header slot="header" />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <h1 class="text-3xl font-extrabold mb-8">Tags</h1>

    <div class="flex flex-wrap gap-3">
      {
        [...tags.entries()].map(([tag, count]) => (
          <a
            href={`/blog-modern/tags/${tag}/`}
            class="group flex items-center gap-2 px-4 py-2.5 rounded-xl border border-surface-200 dark:border-surface-800 hover:border-primary-500/50 hover:bg-primary-500/5 transition-all"
          >
            <span class="font-medium group-hover:text-primary-500 transition-colors">
              #{tag}
            </span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-surface-200 dark:bg-surface-800 text-surface-800/60 dark:text-surface-200/60">
              {count}
            </span>
          </a>
        ))
      }
    </div>
  </div>

  <Footer slot="footer" />
  <BackToTop />
</BaseLayout>
