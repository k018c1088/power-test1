---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import TagCloud from '../../components/TagCloud.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getPublishedPosts, getAllTags } from '../../utils/posts';

const posts = await getPublishedPosts();
const tags = await getAllTags();
---

<BaseLayout title="Blog" description="All articles">
  <Header slot="header" />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <h1 class="text-3xl font-extrabold mb-2">Blog</h1>
    <p class="text-surface-800/60 dark:text-surface-200/60 mb-8">
      All articles ({posts.length})
    </p>

    <!-- Tags -->
    <div class="mb-8">
      <TagCloud tags={tags} />
    </div>

    <!-- Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post, i) => <ArticleCard post={post} index={i} />)}
    </div>

    {
      posts.length === 0 && (
        <div class="text-center py-20 text-surface-800/40 dark:text-surface-200/40">
          <p class="text-lg">No articles yet.</p>
        </div>
      )
    }
  </div>

  <Footer slot="footer" />
  <BackToTop />
</BaseLayout>
