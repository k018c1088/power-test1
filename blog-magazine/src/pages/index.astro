---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ArticleCard from '../components/ArticleCard.astro';
import BackToTop from '../components/BackToTop.astro';
import { getPublishedPosts, getAllTags } from '../utils/posts';
import { getCollection } from 'astro:content';

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 6);
const latestPost = posts[0];
const tags = await getAllTags();
const downloads = await getCollection('downloads');
---

<BaseLayout title="Home">
  <Header slot="header" />

  <!-- Hero -->
  <HeroSection latestPost={latestPost} totalPosts={posts.length} recentPosts={posts.slice(1, 3)} />

  <!-- Latest Posts -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">Latest Articles</h2>
      <a href="/blog-magazine/blog/" class="text-sm font-medium text-primary-500 hover:underline">
        View all &rarr;
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {latestPosts.map((post, i) => <ArticleCard post={post} index={i} />)}
    </div>
  </section>

  <!-- Tags Section -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-16">
    <h2 class="text-2xl font-bold mb-6 reveal">Tags</h2>
    <div class="flex flex-wrap gap-2 reveal reveal-delay-1">
      {
        [...tags.entries()].slice(0, 15).map(([tag, count]) => (
          <a
            href={`/blog-magazine/tags/${tag}/`}
            class="px-4 py-2 rounded-xl bg-surface-200/50 dark:bg-surface-800/50 hover:bg-primary-500/15 hover:text-primary-500 transition-all text-sm font-medium"
          >
            #{tag}
            <span class="ml-1 text-xs opacity-50">{count}</span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Downloads Preview -->
  {
    downloads.length > 0 && (
      <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-16">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold">Downloads</h2>
          <a href="/blog-magazine/downloads/" class="text-sm font-medium text-primary-500 hover:underline">
            View all &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {downloads.slice(0, 4).map((item) => (
            <div class="rounded-xl border border-surface-200 dark:border-surface-800 p-4 bg-surface-50 dark:bg-surface-900 card-3d">
              <h3 class="font-bold mb-1">{item.data.title}</h3>
              <p class="text-sm text-surface-800/60 dark:text-surface-200/60 line-clamp-1">{item.data.description}</p>
            </div>
          ))}
        </div>
      </section>
    )
  }

  <Footer slot="footer" />
  <BackToTop />
</BaseLayout>
