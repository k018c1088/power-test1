---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
  toc.length > 0 && (
    <nav class="toc hidden xl:block sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto">
      <h4 class="text-xs font-semibold uppercase tracking-wider text-surface-800/40 dark:text-surface-200/40 mb-3">
        Table of Contents
      </h4>
      <ul class="space-y-1 text-sm border-l-2 border-surface-200 dark:border-surface-800">
        {toc.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                'block py-1 transition-colors hover:text-primary-500 border-l-2 -ml-[2px]',
                heading.depth === 2 ? 'pl-4' : 'pl-8',
                'border-transparent text-surface-800/60 dark:text-surface-200/60',
              ]}
              data-toc-link={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  function initTOC() {
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
    if (links.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((link) => {
              link.classList.remove('border-primary-500', 'text-primary-500', 'font-medium');
              link.classList.add('border-transparent');
            });
            const activeLink = document.querySelector(
              `[data-toc-link="${entry.target.id}"]`
            );
            if (activeLink) {
              activeLink.classList.add('border-primary-500', 'text-primary-500', 'font-medium');
              activeLink.classList.remove('border-transparent');
            }
          }
        });
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0.5 }
    );

    links.forEach((link) => {
      const slug = link.getAttribute('data-toc-link');
      const heading = document.getElementById(slug ?? '');
      if (heading) observer.observe(heading);
    });
  }

  initTOC();
  document.addEventListener('astro:after-swap', initTOC);
</script>
