---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-surface-200 dark:border-surface-800 mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span
            class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-400 to-accent-500 flex items-center justify-center text-white text-sm font-black"
          >
            M
          </span>
          <span class="font-display font-bold text-lg italic">Magazine</span>
        </div>
        <p class="text-sm text-surface-800/60 dark:text-surface-200/60 leading-relaxed">
          AI・自動化・開発ツールに関する<br />技術ナレッジを発信するブログ
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-semibold mb-3 text-sm uppercase tracking-wider text-surface-800/40 dark:text-surface-200/40">
          Links
        </h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/power-test1/blog-magazine/blog/" class="hover:text-primary-500 transition-colors">Blog</a></li>
          <li><a href="/power-test1/blog-magazine/downloads/" class="hover:text-primary-500 transition-colors">Downloads</a></li>
          <li><a href="/power-test1/blog-magazine/tags/" class="hover:text-primary-500 transition-colors">Tags</a></li>
          <li><a href="/power-test1/blog-magazine/archive/" class="hover:text-primary-500 transition-colors">Archive</a></li>
          <li><a href="/power-test1/blog-magazine/about/" class="hover:text-primary-500 transition-colors">About</a></li>
        </ul>
      </div>

      <!-- Feed -->
      <div>
        <h3 class="font-semibold mb-3 text-sm uppercase tracking-wider text-surface-800/40 dark:text-surface-200/40">
          Subscribe
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/power-test1/blog-magazine/rss.xml" class="flex items-center gap-2 hover:text-primary-500 transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z" />
              </svg>
              RSS Feed
            </a>
          </li>
        </ul>
        <div class="mt-4">
          <a
            href="https://github.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm hover:text-primary-500 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-surface-200 dark:border-surface-800 text-center text-xs text-surface-800/40 dark:text-surface-200/40">
      &copy; {currentYear} TechBlog. Built with Astro & Tailwind CSS.
    </div>
  </div>
</footer>
