---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/date';

interface Props {
  item: CollectionEntry<'downloads'>;
}

const { item } = Astro.props;

const typeIcons: Record<string, string> = {
  script: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  document: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  template: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z',
  tool: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z',
  game: 'M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z',
  site: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
};

const typeLabels: Record<string, string> = {
  script: 'Script',
  document: 'Document',
  template: 'Template',
  tool: 'Tool',
  game: 'Game',
  site: 'Website',
};
---

<div class="rounded-2xl border border-surface-200 dark:border-surface-800 p-5 bg-surface-50 dark:bg-surface-900 card-3d group">
  <div class="flex items-start gap-4">
    <!-- Icon -->
    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary-400/20 to-accent-500/20 flex items-center justify-center flex-shrink-0">
      <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={typeIcons[item.data.type] || typeIcons.tool} />
      </svg>
    </div>

    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <span class="px-2 py-0.5 text-[10px] font-semibold uppercase rounded-md bg-primary-500/15 text-primary-600 dark:text-primary-400">
          {typeLabels[item.data.type]}
        </span>
        <span class="text-xs text-surface-800/40 dark:text-surface-200/40">
          v{item.data.version}
        </span>
      </div>

      <h3 class="font-bold text-base mb-1 truncate">{item.data.title}</h3>
      <p class="text-sm text-surface-800/60 dark:text-surface-200/60 line-clamp-2 mb-3">
        {item.data.description}
      </p>

      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3 text-xs text-surface-800/40 dark:text-surface-200/40">
          <span>{formatDate(item.data.pubDate)}</span>
          {item.data.fileSize && <span>{item.data.fileSize}</span>}
        </div>

        <a
          href={`/blog-magazine/downloads/${item.data.fileName}`}
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg bg-primary-500 text-white hover:bg-primary-600 transition-colors download-btn"
          data-file={item.data.fileName}
          download
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download
        </a>
      </div>
    </div>
  </div>
</div>
